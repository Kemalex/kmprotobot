# ════════════════════════════════════════════
#  Telegram Proxy Bot — конфигурация
#  Скопируй в .env и заполни значения
# ════════════════════════════════════════════

# Токен бота (получить у @BotFather)
BOT_TOKEN=8318894708:AAGRMbUmdrHbRdr_DNy2qdwIV_nPsj_voUY

# ID администраторов через запятую (получить у @userinfobot)
ADMIN_IDS=123456789,987654321

# ── Параметры обновления ─────────────────────────────────────────────────────

# Интервал автообновления базы прокси (секунды, по умолчанию 3600 = 1 час)
AUTO_UPDATE_INTERVAL=3600

# Уведомлять подписчиков при каждом обновлении (true/false)
AUTO_NOTIFY_USERS=true

# ── Проверка прокси ───────────────────────────────────────────────────────────

# Таймаут TCP-проверки (секунды)
CHECK_TIMEOUT=8

# Максимальный приемлемый пинг (мс)
MAX_PING_MS=3000

# Сколько топ-прокси хранить в базе
TOP_PROXIES_COUNT=10

# ── Предпочтения по умолчанию ────────────────────────────────────────────────

# Регион по умолчанию: ru / eu / all
DEFAULT_REGION=all

# Тип прокси: mtproto / socks5
DEFAULT_PROXY_TYPE=mtproto

# ── Хранилище ────────────────────────────────────────────────────────────────

# Путь к SQLite базе (по умолчанию — рядом с ботом)
DB_PATH=proxy_bot.db
